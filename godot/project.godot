; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Void Sovereigns"
config/tags=PackedStringArray("fps", "singleplayer", "horror", "extraction")
run/main_scene="res://scenes/hub.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Global="*res://scripts/Global.gd"
MissionState="*res://scripts/autoloads/MissionState.gd"
EconomyState="*res://scripts/autoloads/EconomyState.gd"
LoadoutState="*res://scripts/autoloads/LoadoutState.gd"
SurvivalState="*res://scripts/autoloads/SurvivalState.gd"
ProgressionState="*res://scripts/autoloads/ProgressionState.gd"
SceneManager="*res://scripts/autoloads/SceneManager.gd"
GameAssetManager="*res://scripts/autoloads/GameAssetManager.gd"
DataManager="*res://scripts/content/DataManager.gd"

[debug]

gdscript/warnings/untyped_declaration=1

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/vsync/vsync_mode=0

